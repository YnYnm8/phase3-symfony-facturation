{% extends 'base.html.twig' %}

{% block title %}Mon Profil – FacturSaaS{% endblock %}

{% block body %}


  

    {# ===== MAIN ===== #}
  
        <h1 class="text-2xl font-bold text-gray-800 mb-6">Mon Profil</h1>

        {# Flash message #}
        {% for message in app.flashes('success') %}
            <div class="mb-4 px-4 py-3 bg-green-50 border border-green-200 text-green-700 rounded-lg text-sm">
                {{ message }}
            </div>
        {% endfor %}

        <div class="bg-white rounded-xl border border-gray-100 shadow-sm p-6 max-w-2xl">

            {{ form_start(profileForm, {'attr': {'class': 'flex flex-col gap-5'}}) }}

                {# Raison Sociale #}
                <div>
                    {{ form_label(profileForm.company_name, null, {'label_attr': {'class': 'block text-sm font-medium text-gray-700 mb-1'}}) }}
                    {{ form_widget(profileForm.company_name, {'attr': {'class': 'w-full px-3 py-2 border border-gray-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-blue-500'}}) }}
                    {{ form_help(profileForm.company_name) }}
                    {{ form_errors(profileForm.company_name) }}
                </div>

                {# SIRET #}
                <div>
                    {{ form_label(profileForm.siret, null, {'label_attr': {'class': 'block text-sm font-medium text-gray-700 mb-1'}}) }}
                    {{ form_widget(profileForm.siret, {'attr': {'class': 'w-full px-3 py-2 border border-gray-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-blue-500'}}) }}
                    {{ form_errors(profileForm.siret) }}
                </div>

                {# IBAN #}
                <div>
                    {{ form_label(profileForm.iban, null, {'label_attr': {'class': 'block text-sm font-medium text-gray-700 mb-1'}}) }}
                    {{ form_widget(profileForm.iban, {'attr': {'class': 'w-full px-3 py-2 border border-gray-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-blue-500'}}) }}
                    {{ form_help(profileForm.iban) }}
                    {{ form_errors(profileForm.iban) }}
                </div>

                {# CGV #}
                <div>
                    {{ form_label(profileForm.cgv, null, {'label_attr': {'class': 'block text-sm font-medium text-gray-700 mb-1'}}) }}
                    {{ form_widget(profileForm.cgv, {'attr': {'class': 'w-full px-3 py-2 border border-gray-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-blue-500 h-32 resize-none'}}) }}
                    {{ form_errors(profileForm.cgv) }}
                </div>

                {# Submit #}
                <div>
                    <button type="submit"
                            class="px-5 py-2.5 bg-blue-600 text-white text-sm font-medium rounded-lg hover:bg-blue-700 transition-colors">
                        Enregistrer les modifications
                    </button>
                </div>

            {{ form_end(profileForm) }}

        </div>
  

{% endblock %}