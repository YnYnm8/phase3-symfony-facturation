{% extends 'base.html.twig' %}
{% block title %}Créer une facture
{% endblock %}

{% block body %}
	<div class="p-8 max-w-4xl">

		<a href="{{ path('app_invoice_index') }}" class="flex items-center gap-2 text-sm text-gray-500 hover:text-gray-700 mb-4">
			← Retour aux factures
		</a>
		<h1 class="text-2xl font-bold text-gray-800 mb-6">Créer une facture</h1>

		{{ form_start(form, {'attr': {'data-turbo': 'false'}}) }}

		<div class="bg-white rounded-xl border border-gray-200 p-6 mb-4">
			<h2 class="font-semibold text-gray-800 mb-4">Informations Générales</h2>
			<div class="flex gap-4">
				<div class="flex-1">
					{{ form_label(form.client, null, {'label_attr': {'class': 'block text-sm text-gray-600 mb-1'}}) }}
					<div class="flex gap-2">
						{{ form_widget(form.client, {'attr': {'class': 'flex-1 px-3 py-2 border border-gray-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-blue-500'}}) }}
						<a href="{{ path('app_client_new') }}" class="px-3 py-2 border border-gray-300 rounded-lg text-gray-500 hover:bg-gray-50">+</a>
					</div>
					{{ form_errors(form.client) }}
				</div>
				<div class="flex-1">
					<label class="block text-sm text-gray-600 mb-1">Date de la facture</label>
					<input type="text" value="{{ 'now'|date('d/m/Y') }}" class="w-full px-3 py-2 border border-gray-300 rounded-lg text-sm bg-gray-50" readonly>
				</div>
			</div>
		</div>

		<div class="bg-white rounded-xl border border-gray-200 p-6 mb-4">
			<h2 class="font-semibold text-gray-800 mb-4">Lignes de la facture</h2>
			<table class="w-full text-sm mb-4">
				<thead>
					<tr class="border-b border-gray-200">
						<th class="text-left py-2 text-gray-500 font-medium">Produit / Service</th>
						<th class="text-center py-2 text-gray-500 font-medium">Qté</th>
						<th class="text-right py-2 text-gray-500 font-medium">Prix Unitaire</th>
						<th class="text-right py-2 text-gray-500 font-medium">Total</th>
						<th></th>
					</tr>
				</thead>
				<tbody id="invoice-lines"></tbody>
			</table>

			<div class="flex gap-3 items-end border-t border-gray-100 pt-4">
				<div class="flex-1">
					<label class="block text-xs text-gray-500 mb-1">Sélectionner un produit</label>

					<select id="select-product" class="w-full px-3 py-2 border border-gray-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-blue-500">
						<option value="">-- Choisir --</option>
						{% for product in products %}
							<option value="{{ product.id }}" data-price="{{ product.price }}" data-name="{{ product.name }}">
								{{ product.name }}
							</option>
						{% endfor %}
					</select>
				</div>
				<div class="w-24">
					<label class="block text-xs text-gray-500 mb-1">Quantité</label>
					<input type="number" id="input-quantity" value="1" min="1" class="w-full px-3 py-2 border border-gray-300 rounded-lg text-sm">
				</div>
				<div class="w-32">
					<label class="block text-xs text-gray-500 mb-1">Prix unitaire (€)</label>
					<input type="number" id="input-price" step="0.01" class="w-full px-3 py-2 border border-gray-300 rounded-lg text-sm">
				</div>
				<button type="button" onclick="addLine()" class="px-4 py-2 bg-gray-700 text-white text-sm rounded-lg hover:bg-gray-800">
					+ Ajouter
				</button>
			</div>

			<div class="flex justify-end mt-4 pt-4 border-t border-gray-100">
				<span class="font-semibold text-gray-700 mr-4">Total Facture (TTC) :</span>
				<span id="total" class="font-bold text-blue-600 text-lg">0.00 €</span>
			</div>
		</div>

		<div id="hidden-inputs"></div>

		<div class="flex justify-center gap-4">
			<a href="{{ path('app_invoice_index') }}" class="px-6 py-2 text-sm text-gray-600 border border-gray-300 rounded-lg hover:bg-gray-50">
				Annuler
			</a>
			<button type="submit" name="action" value="draft" class="px-6 py-2 text-sm text-blue-600 border border-blue-300 rounded-lg hover:bg-blue-50">
				Enregistrer en brouillon
			</button>
			<button type="submit" name="action" value="validate" class="px-6 py-2 text-sm text-white bg-blue-600 rounded-lg hover:bg-blue-700">
				Enregistrer et valider
			</button>
		</div>

		{{ form_end(form) }}
	</div>

	 <script>
			(function() {
			    let lines = [];
			    let lineIndex = 0;
			
			    document.getElementById('select-product').addEventListener('change', function() {
			        const option = this.options[this.selectedIndex];
			        document.getElementById('input-price').value = option.dataset.price || '';
			    });
			
			    function addLine() {
			        const select = document.getElementById('select-product');
			        const quantity = document.getElementById('input-quantity').value;
			        const price = document.getElementById('input-price').value;
			        const option = select.options[select.selectedIndex];
			
			        if (!select.value) {
			            alert('Veuillez sélectionner un produit.');
			            return;
			        }
			
			        const line = {
			            index: lineIndex,
			            productId: select.value,
			            name: option.dataset.name,
			            quantity: parseInt(quantity),
			            price: parseFloat(price),
			            total: parseInt(quantity) * parseFloat(price)
			        };
			
			        lines.push(line);
			        lineIndex++;
			        renderLines();
			        updateTotal();
			    }
			
			    function renderLines() {
			        const tbody = document.getElementById('invoice-lines');
			        const hiddenInputs = document.getElementById('hidden-inputs');
			
			        tbody.innerHTML = '';
			        hiddenInputs.innerHTML = '';
			
			        lines.forEach(function(line, i) {
			            tbody.innerHTML += `
			                <tr class="border-b border-gray-100">
			                    <td class="py-3 text-gray-800">${line.name}</td>
			                    <td class="py-3 text-center text-gray-600">${line.quantity}</td>
			                    <td class="py-3 text-right text-gray-600">${line.price.toFixed(2)} €</td>
			                    <td class="py-3 text-right text-gray-800">${line.total.toFixed(2)} €</td>
			                    <td class="py-3 text-right">
			                        <button type="button" onclick="removeLine(${line.index})" class="text-red-400 hover:text-red-600">🗑️</button>
			                    </td>
			                </tr>
			            `;
			            hiddenInputs.innerHTML += `
			                <input type="hidden" name="lines[${i}][productId]" value="${line.productId}">
			                <input type="hidden" name="lines[${i}][quantity]" value="${line.quantity}">
			                <input type="hidden" name="lines[${i}][unitPrice]" value="${line.price}">
			            `;
			        });
			    }
			
			    function updateTotal() {
			        const total = lines.reduce(function(sum, line) {
			            return sum + line.total;
			        }, 0);
			        document.getElementById('total').textContent = total.toFixed(2) + ' €';
			    }
			
			    function removeLine(index) {
			        lines = lines.filter(function(line) {
			            return line.index !== index;
			        });
			        renderLines();
			        updateTotal();
			    }
			
			    window.addLine = addLine;
			    window.removeLine = removeLine;
			})();
			</script>
{% endblock %}
