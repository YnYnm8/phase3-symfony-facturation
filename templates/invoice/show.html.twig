{% extends 'base.html.twig' %}
{% block title %}Facture
	{{ invoice.number }}
{% endblock %}

{% block body %}
	<div
		class="p-8 max-w-4xl">

		{# 戻るリンク #}
		<a href="{{ path('app_invoice_index') }}" class="flex items-center gap-2 text-sm text-gray-500 hover:text-gray-700 mb-4">
			← Retour aux factures
		</a>

		{# ヘッダー：番号・status・ボタン #}
		<div class="flex items-center justify-between mb-2">
			<div class="flex items-center gap-3">
				<h1 class="text-xl font-bold text-gray-800">Facture
					{{ invoice.number }}</h1>
				{# statusバッジ #}
				{% if invoice.status.value == 'draft' %}
					<span class="px-2 py-1 text-xs rounded-full bg-gray-100 text-gray-600">Brouillon</span>
				{% elseif invoice.status.value == 'pending_payment' %}
					<span class="px-2 py-1 text-xs rounded-full bg-orange-100 text-orange-600">En attente</span>
				{% elseif invoice.status.value == 'paid' %}
					<span class="px-2 py-1 text-xs rounded-full bg-green-100 text-green-600">Payée</span>
				{% endif %}
			</div>
			<div
				class="flex gap-3">

				{# DRAFTのとき #}
				{% if invoice.status.value == 'draft' %}
					<form method="post" action="{{ path('app_invoice_validate', {'id': invoice.id}) }}" onsubmit="return confirm('Valider cette facture ?')">
						<input type="hidden" name="_token" value="{{ csrf_token('validate' ~ invoice.id) }}">
						<button type="submit" class="px-4 py-2 text-sm text-white bg-green-500 rounded-lg">
							✓ Valider la facture
						</button>
					</form>
					{{ include('invoice/_delete_form.html.twig') }}
				{% endif %}

				{# En attenteのとき #}
				{% if invoice.status.value == 'pending_payment' %}
					<form method="post" action="{{ path('app_invoice_pay', {'id': invoice.id}) }}" onsubmit="return confirm('Marquer comme payée ?')">
						<input type="hidden" name="_token" value="{{ csrf_token('pay' ~ invoice.id) }}">
						<button type="submit" class="px-4 py-2 text-sm text-white bg-green-500 rounded-lg">
							€ Valider le paiement
						</button>
					</form>
				{% endif %}
				{# EN ATTENTEまたはPAIDのときPDFボタンを表示 #}
				{% if invoice.status.value != 'draft' %}
					<a href="{{ path('app_invoice_pdf', {'id': invoice.id}) }}" class="px-4 py-2 text-sm text-white bg-blue-600 rounded-lg hover:bg-blue-700">
						📄 PDF
					</a>
				{% endif %}

			</div>

		</div>

		<p class="text-sm text-gray-500 mb-6">Date :
			{{ invoice.createdAt|date('d/m/Y') }}</p>

		{# 請求書本体 #}
		<div
			class="bg-white rounded-xl border border-gray-200 p-8 mb-4">

			{# 上部：自分の会社情報 + FACTURE #}
			<div class="flex justify-between mb-8">
				<div>
					<p class="font-bold text-gray-800">{{ invoice.owner.companyName }}</p>
					<p class="text-sm text-gray-500">{{ invoice.owner.firstName }}
						{{ invoice.owner.lastName }}</p>
					<p class="text-sm text-gray-500">{{ invoice.owner.email }}</p>
				</div>
				<div class="text-right">
					<p class="text-xl font-bold text-gray-800">FACTURE</p>
					<p class="text-sm text-gray-500">N°
						{{ invoice.number }}</p>
					<p class="text-sm text-gray-500">Date :
						{{ invoice.createdAt|date('d/m/Y') }}</p>
				</div>
			</div>

			{# 宛先（FACTURÉ À） #}
			<div class="bg-gray-50 rounded-lg p-4 mb-8 ml-auto w-64">
				<p class="text-xs text-gray-400 mb-2">FACTURÉ À</p>
				<p class="font-semibold text-gray-800">{{ invoice.client.name }}</p>
				<p class="text-sm text-gray-500">{{ invoice.client.adress }}</p>
				<p class="text-sm text-gray-500">{{ invoice.client.email }}</p>
				{% if invoice.client.siret %}
					<p class="text-sm text-gray-500">SIRET :
						{{ invoice.client.siret }}</p>
				{% endif %}
			</div>

			{# 商品テーブル #}
			<table class="w-full text-sm mb-6">
				<thead>
					<tr class="border-b border-gray-200">
						<th class="text-left py-2 text-gray-500 font-medium">Description</th>
						<th class="text-center py-2 text-gray-500 font-medium">Qté</th>
						<th class="text-right py-2 text-gray-500 font-medium">Prix Unitaire</th>
						<th class="text-right py-2 text-gray-500 font-medium">Total TTC</th>
					</tr>
				</thead>
				<tbody>
					{% for item in invoice.invoiceItems %}
						<tr class="border-b border-gray-100">
							<td class="py-3">
								<p class="font-medium text-gray-800">{{ item.product.name }}</p>
								<p class="text-xs text-gray-400">{{ item.product.description }}</p>
							</td>
							<td class="py-3 text-center text-gray-600">{{ item.quantity }}</td>
							<td class="py-3 text-right text-gray-600">{{ item.unitPrice }}
								€</td>
							<td class="py-3 text-right font-medium text-gray-800">{{ item.quantity * item.unitPrice }}
								€</td>
						</tr>
					{% endfor %}
				</tbody>
			</table>

			{# 合計 #}
			<div class="flex flex-col items-end gap-1 border-t border-gray-200 pt-4">
				<div class="flex gap-8 text-sm text-gray-500">
					<span>Total HT</span>
					<span>{{ invoice.totalTtc }}
						€</span>
				</div>
				<div class="flex gap-8 font-bold text-gray-800 text-lg">
					<span>Total TTC</span>
					<span class="text-blue-600">{{ invoice.totalTtc }}
						€</span>
				</div>
				<p class="text-xs text-gray-400 mt-1">TVA non applicable, art. 293 B du CGI</p>
			</div>

			{# 支払い条件・IBAN #}
			<div class="border-t border-gray-200 mt-6 pt-4">
				<p class="text-sm font-medium text-gray-700 mb-2">Conditions de paiement</p>
				<div class="bg-gray-50 rounded-lg p-3">
					<p class="text-xs text-gray-500">Coordonnées bancaires pour le paiement :</p>
					<p class="text-sm text-gray-700 font-medium">{{ invoice.owner.iban }}</p>
				</div>
			</div>

		</div>

	</div>
{% endblock %}
