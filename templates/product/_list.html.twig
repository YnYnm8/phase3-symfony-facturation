


{# Table #}
		<div class="flex items-end　 bg-white rounded-xl border border-gray-200 overflow-hidden">
			<table class="w-full text-sm">
				<thead>
					<tr class="border-b border-gray-200">
						<th class="text-left px-6 py-3 text-gray-500 font-medium">Nom</th>
						<th class="text-left px-6 py-3 text-gray-500 font-medium">Description</th>
						<th class="text-left px-6 py-3 text-gray-500 font-medium">Prix unitaire</th>
						<th class="text-right px-6 py-3 text-gray-500 font-medium">Actions</th>
					</tr>
				</thead>
				<tbody>
					{% for product in products %}
						<tr class="border-b border-gray-100 hover:bg-gray-50 transition-colors">
							<td class="px-6 py-4 text-gray-800">{{ product.name }}</td>
							<td class="px-6 py-4 text-gray-500">{{ product.description }}</td>
							<td class="px-6 py-4 text-gray-800">
								{{ product.price }}
								€ /
								{{ product.unit.value }}
							</td>
							<td class="px-6 py-4">
								<div class="flex items-center justify-end gap-3">
									<a href="{{ path('app_product_edit', {'id': product.id}) }}" class="text-blue-500 hover:text-blue-700 transition-colors">
										<i data-lucide="pen" class="w-4 h-4"></i>
									</a>
									<form method="post" action="{{ path('app_product_delete', {'id': product.id}) }}" onsubmit="return confirm('Supprimer ce produit ?')">
										<input type="hidden" name="_method" value="DELETE">
										<input type="hidden" name="_token" value="{{ csrf_token('delete' ~ product.id) }}">
										<button type="submit" class="text-red-400 hover:text-red-600 transition-colors">
											<i data-lucide="trash-2" class="w-4 h-4"></i>
										</button>
									</form>
								</div>
							</td>
						</tr>
					{% else %}
						<tr>
							<td colspan="4" class="px-6 py-8 text-center text-gray-400">
								Aucun produit trouvé
							</td>
						</tr>
					{% endfor %}
				</tbody>
			</table>
		</div>

	</div>

	 <script>lucide.createIcons();</script>
