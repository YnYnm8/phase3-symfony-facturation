{% extends 'base.html.twig' %}
{% block title %}Nouveau Produit
{% endblock %}
{% block body %}


	<div class="min-h-screen bg-gray-100 flex-row gap-9">
		<div
			class="bg-white rounded-xl shadow-lg w-full max-w-md p-6 relative">

			{# Close button #}
			<a href="{{ path('app_product_index') }}" class="absolute top-4 right-4 text-gray-400 hover:text-gray-600 text-xl leading-none">✕</a>

			{# Title #}
			<h1 class="text-lg font-semibold text-gray-800 mb-1 items-center justify-center">Produit</h1>
			<p class="text-sm text-gray-500 mb-5">Modifier un produit</p>

			{# Form #}
			{{ form_start(form, {'attr': {'class': 'flex flex-col gap-4'}}) }}

			{# Nom #}
			<div>
				{{ form_label(form.name, null, {'label_attr': {'class': 'block text-sm text-gray-600 mb-1'}}) }}
				{{ form_widget(form.name, {'attr': {'class': 'w-full px-3 py-2 border border-gray-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-blue-500'}}) }}
				{{ form_errors(form.name) }}
			</div>

			{# Description #}
			<div>
				{{ form_label(form.description, null, {'label_attr': {'class': 'block text-sm text-gray-600 mb-1'}}) }}
				{{ form_widget(form.description, {'attr': {'class': 'w-full px-3 py-2 border border-gray-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-blue-500'}}) }}
				{{ form_errors(form.description) }}
			</div>

			{# Prix + Unité côte à côte #}
			<div class="flex gap-4">
				<div class="flex-1">
					{{ form_label(form.price, null, {'label_attr': {'class': 'block text-sm text-gray-600 mb-1'}}) }}
					{{ form_widget(form.price, {'attr': {'class': 'w-full px-3 py-2 border border-gray-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-blue-500'}}) }}
					{{ form_errors(form.price) }}
				</div>
				<div class="flex-1">
					{{ form_label(form.unit, null, {'label_attr': {'class': 'block text-sm text-gray-600 mb-1'}}) }}
					{{ form_widget(form.unit, {'attr': {'class': 'w-full px-3 py-2 border border-gray-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-blue-500'}}) }}
					{{ form_errors(form.unit) }}
				</div>
			</div>

			{# Buttons #}
			<div class="flex justify-end gap-3 mt-2">
				<a href="{{ path('app_product_index') }}" class="px-4 py-2 text-sm text-gray-600 border border-gray-300 rounded-lg hover:bg-gray-50 transition-colors">
					Annuler
				</a>
				<button type="submit" class="px-4 py-2 text-sm text-white bg-blue-600 rounded-lg hover:bg-blue-700 transition-colors">
					Enregistrer
				</button>
			</div>

			{{ form_end(form) }}

		</div>
		{# 一覧を呼び出す #}
		{% include 'product/_list.html.twig' %}
	</div>

{% endblock %}
